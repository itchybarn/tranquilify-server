# Database.
# SQLAlchemy URL format: <dialect>+<driver>
# URL uses RDMBS and Driver ^^^, Username, Password, Host, Port, DB name (must match POSTGRES_DB in compose)
DATABASE_URL=postgresql+asyncpg://tranquilify:tranquilify@db:5432/tranquilify

# JWT / access tokens
# JWT_SECRET_KEY: long random secret used to sign access tokens (keep out of source control)
# JWT_ALGO: signing algorithm, e.g. HS256
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGO=HS256

# Twilio (SMS 2FA)
# From the Twilio console. TRANQUILIFY_SERVICE_SID is the Verify service SID (starts with VA...)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CLIENT_SECRET=your-twilio-auth-token
TRANQUILIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
